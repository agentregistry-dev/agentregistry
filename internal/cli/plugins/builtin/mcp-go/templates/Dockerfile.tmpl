# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Glob the optional go.sum: it isn't shipped by `arctl init` (it gets
# generated by `go mod download` below). The bracketed glob `go.su[m]`
# matches go.sum if present, no-ops if not.
COPY go.mod go.su[m] ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /app/server ./cmd/server

# Final stage
FROM alpine

WORKDIR /app

COPY --from=builder /app/server /app/server

EXPOSE 8080

ENTRYPOINT ["/app/server"] 